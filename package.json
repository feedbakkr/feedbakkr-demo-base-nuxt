{
  "name": "feedbakkr-demo-base-nuxt",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "security:audit": "pnpm audit --audit-level high",
    "security:audit:moderate": "pnpm audit --audit-level moderate",
    "security:osv": "osv-scanner --recursive .",
    "security:scan": "pnpm run security:audit && pnpm run security:osv",
    "security:scan:full": "pnpm run security:audit:moderate && pnpm run security:osv"
  },
  "dependencies": {
    "nuxt": "^3.21.2",
    "vue": "^3.5.13",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "typescript": "^5.6.3"
  },
  "pnpm": {
    "overrides": {
      "devalue": ">=5.8.1"
    }
  }
}
